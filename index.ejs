<script>
  const createBtn = document.querySelector('button:has(span:contains("+"))');
  const modal = document.getElementById('createRoomModal');
  const cancelBtn = document.getElementById('cancelModal');
  const form = document.getElementById('createRoomForm');

  // Open modal
  createBtn.addEventListener('click', () => {
    modal.classList.remove('hidden');
  });

  // Close modal
  cancelBtn.addEventListener('click', () => {
    modal.classList.add('hidden');
    form.reset();
  });

  // Submit form (you can replace this with a POST request)
  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const roomName = data.get('roomName');
    const category = data.get('category');
    const description = data.get('description');

    console.log({ roomName, category, description }); // Replace with actual logic

    modal.classList.add('hidden');
    form.reset();
  });
</script>
    <script>
  const searchInput = document.querySelector('input[type="text"]');
  const filterButtons = document.querySelectorAll('.filter-btn');
  const chatrooms = document.querySelectorAll('.chatroom');

  // Filter chatrooms by tag
  function filterChatrooms(tag) {
    chatrooms.forEach(room => {
      const roomTag = room.dataset.tag.toLowerCase();
      if (tag === 'all' || roomTag.includes(tag)) {
        room.style.display = 'block';
      } else {
        room.style.display = 'none';
      }
    });
  }

  // Handle button click
  filterButtons.forEach(button => {
    button.addEventListener('click', () => {
      const tag = button.dataset.tag.toLowerCase();
      searchInput.value = tag === 'all' ? '' : tag;

      // Highlight active button
      filterButtons.forEach(btn => btn.classList.remove('active'));
      button.classList.add('active');

      filterChatrooms(tag);
    });
  });

  // Handle search input
  searchInput.addEventListener('input', () => {
    const query = searchInput.value.toLowerCase();
    filterButtons.forEach(btn => btn.classList.remove('active'));
    filterChatrooms(query);
  });
</script>
