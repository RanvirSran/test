    <form id="createRoomForm" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-slate-700">Room Name</label>
        <input type="text" name="roomName" required class="w-full mt-1 px-3 py-2 border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm">
